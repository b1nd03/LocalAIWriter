<Window x:Class="LocalAIWriter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalAI Writer — Settings"
        Width="680" Height="580"
        MinWidth="580" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar -->
            <RowDefinition Height="*"/>     <!-- content -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Title Bar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="8"
                        Background="{DynamicResource PrimaryBrush}"
                        Margin="0,0,10,0">
                    <TextBlock Text="✦" FontSize="13" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="LocalAI Writer" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  ·  Settings" FontSize="14"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Main Content: Sidebar + Content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar nav -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="10,14">
                <ListBox x:Name="NavList"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="OnNavChanged"
                         SelectedIndex="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="8"
                                                Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBoxItem Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Width="20" FontSize="14" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="General" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨" Width="20" FontSize="14" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="Hotkey" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨" Width="20" FontSize="14" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="Appearance" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♿" Width="20" FontSize="14" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="Accessibility" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Width="20" FontSize="14" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="Status" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <!-- Content panels, swapped by code-behind -->
            <ScrollViewer Grid.Column="1" x:Name="ContentArea"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28,24">
                <Grid>

                <!-- General -->
                <StackPanel x:Name="PanelGeneral">
                    <TextBlock Text="General" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <CheckBox Content="Enable AI Writing Assistance"
                              IsChecked="{Binding IsEnabled}"
                              FontSize="13" Margin="0,0,0,10"/>
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding StartWithWindows}"
                              FontSize="13" Margin="0,0,0,10"/>
                    <CheckBox Content="Show floating Improve button"
                              IsChecked="{Binding ShowImproveButton}"
                              FontSize="13" Margin="0,0,0,20"/>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="Aggressiveness" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="How many rules are applied." FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <DockPanel Width="240" HorizontalAlignment="Left">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding AggressivenessLabel}"
                                   FontSize="12" Foreground="{DynamicResource PrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Slider Minimum="0" Maximum="2"
                                Value="{Binding AggressivenessLevel}"
                                IsSnapToTickEnabled="True"
                                TickPlacement="None"/>
                    </DockPanel>

                    <TextBlock Text="Writing Style" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,20,0,4"/>
                    <ComboBox SelectedIndex="{Binding WritingStyle}" Width="240" HorizontalAlignment="Left">
                        <ComboBoxItem Content="General"/>
                        <ComboBoxItem Content="Academic"/>
                        <ComboBoxItem Content="Business"/>
                        <ComboBoxItem Content="Creative"/>
                        <ComboBoxItem Content="Technical"/>
                    </ComboBox>

                    <Separator Margin="0,20,0,16"/>

                    <TextBlock Text="AI Engine (Ollama)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Set local or cloud endpoint and choose any installed model."
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>

                    <TextBlock Text="Endpoint" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"
                             Width="420" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                    <TextBlock Text="Model" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableOllamaModels}"
                              SelectedItem="{Binding OllamaModel}"
                              Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Width="320" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh Models"
                                Command="{Binding RefreshModelsCommand}"
                                Padding="12,6"
                                Style="{DynamicResource SecondaryButton}"/>
                        <TextBlock Text="Refreshing..."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRefreshingModels}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="{Binding ActiveModelLabel}"
                               FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ModelStatus}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <!-- Hotkey (hidden by default) -->
                <StackPanel x:Name="PanelHotkey" Visibility="Collapsed">
                    <TextBlock Text="Hotkey" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    <TextBlock Text="The keyboard shortcut to trigger AI grammar correction."
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,20"/>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="20,16" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Active Hotkey" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Padding="16,8"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + Alt + G" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="20,16" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="How to use" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                1. Select text in any application
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                                2. Press Ctrl+Alt+G
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                                3. Wait for the notification — corrected text is pasted automatically
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Appearance (hidden by default) -->
                <StackPanel x:Name="PanelAppearance" Visibility="Collapsed">
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox SelectedIndex="{Binding Theme}" Width="200" HorizontalAlignment="Left" Margin="0,0,0,24">
                        <ComboBoxItem Content="System Default"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>

                    <Separator Margin="0,0,0,20"/>

                    <TextBlock Text="Popup Timeout (ms)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="How long the suggestion popup stays visible." FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding PopupTimeoutMs}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                    <TextBlock Text="Max Suggestions" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <DockPanel Width="240" HorizontalAlignment="Left">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding MaxSuggestions}"
                                   FontSize="12" Foreground="{DynamicResource PrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Slider Minimum="1" Maximum="10"
                                Value="{Binding MaxSuggestions}"
                                IsSnapToTickEnabled="True"
                                TickPlacement="None"/>
                    </DockPanel>
                </StackPanel>

                <!-- Accessibility (hidden by default) -->
                <StackPanel x:Name="PanelAccessibility" Visibility="Collapsed">
                    <TextBlock Text="Accessibility" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <CheckBox Content="High Contrast Mode"
                              IsChecked="{Binding HighContrast}"
                              FontSize="13" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,20"/>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Keyboard Navigation" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                All controls support Tab / Shift+Tab navigation.
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,6,0,0">
                                Use Ctrl+Alt+G in any application to trigger grammar correction.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Status (hidden by default) -->
                <StackPanel x:Name="PanelStatus" Visibility="Collapsed">
                    <TextBlock Text="Status" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <UniformGrid Columns="2" Rows="2">
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                Padding="16,14" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="AI Engine" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding ModelStatus}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding ActiveModelLabel}" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                Padding="16,14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Total Corrections" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding TotalCorrections}" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                Padding="16,14" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Acceptance Rate" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding AcceptanceRate, StringFormat={}{0:P0}}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Memory Usage" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding MemoryUsage}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="LocalAI Writer v1.1"
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                            Click="OnCancel"
                            Style="{DynamicResource SecondaryButton}"/>
                    <Button Content="Save Changes" Padding="16,8"
                            Click="OnSave"
                            Style="{DynamicResource PrimaryButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
